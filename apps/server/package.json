{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@clerk/express": "^2.0.5",
    "@neondatabase/serverless": "^1.0.2",
    "@t3-oss/env-core": "^0.13.1",
    "bullmq": "^5.76.9",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "express": "^5.1.0",
    "ioredis": "^5.10.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "drizzle-kit": "^0.31.8",
    "tsdown": "^0.21.9",
    "typescript": "catalog:"
  }
}
